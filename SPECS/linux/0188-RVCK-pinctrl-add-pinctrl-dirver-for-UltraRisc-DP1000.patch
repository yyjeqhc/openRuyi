+
+static struct ur_pinctrl_match_data ur_dp1000_match_data = {
+	.pins = ur_dp1000_pins,
+	.npins = ARRAY_SIZE(ur_dp1000_pins),
+	.offset = 0x2c0,
+	.ports = {
+		{"A", 16, 0x2c0, 0x310},
+		{"B", 8, 0x2c4, 0x318},
+		{"C", 8, 0x2c8, 0x31c},
